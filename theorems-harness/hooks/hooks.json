{
  "description": "Theorem Context lifecycle hooks for Claude Code. Out-of-band orchestration before each model turn; action recording after each tool use; run finalization at session end. Mirrors the schema of codex-hooks.json but uses Claude Code's ${CLAUDE_PLUGIN_ROOT} env var and shell:bash invocation style.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|resume",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/begin-run.sh",
            "timeout": 15,
            "statusMessage": "Starting theorem harness run"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/sessionstart-codebase.sh",
            "timeout": 10,
            "statusMessage": "Loading codebase context"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-harness-directives.sh",
            "timeout": 5,
            "statusMessage": "Injecting harness directives"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/prepare-context.sh",
            "timeout": 30,
            "statusMessage": "Preparing theorem context"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-harness-directives.sh",
            "timeout": 5,
            "statusMessage": "Injecting harness directives"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/checklist-contract.sh",
            "timeout": 10,
            "statusMessage": "Emitting harness checklist"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/subagent-suggest.sh",
            "timeout": 10,
            "statusMessage": "Suggesting subagents"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_theorems-harness_.*|mcp__theorems-harness__.*|mcp__rustyred-thg__.*",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/auto-approve-harness.sh",
            "timeout": 5,
            "statusMessage": "Authorizing harness tool"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/enforce-action-rail.sh",
            "timeout": 5,
            "statusMessage": "Checking theorem action rail"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pretool-context.sh",
            "timeout": 10,
            "statusMessage": "Loading pre-tool context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/record-action.sh",
            "timeout": 10,
            "statusMessage": "Recording theorem action"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/posttool-context.sh",
            "timeout": 10,
            "statusMessage": "Recording post-tool context"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/posttool-event.sh",
            "timeout": 10,
            "statusMessage": "Recording coordination event"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/filechange-context.sh",
            "timeout": 5,
            "statusMessage": "Capturing file-change context"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/filechange-reingest.sh",
            "timeout": 5,
            "statusMessage": "Reingesting changed files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/checklist-gate.sh",
            "timeout": 10,
            "statusMessage": "Checking harness checklist"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stop-style-receipt.sh",
            "timeout": 10,
            "statusMessage": "Recording writing style receipt"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/sessionend-context.sh",
            "timeout": 10,
            "statusMessage": "Flushing session-end context"
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/finalize-run.sh",
            "timeout": 30,
            "statusMessage": "Finalizing theorem run"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/precompact-flush.sh",
            "timeout": 10,
            "statusMessage": "Flushing context before compaction"
          }
        ]
      }
    ]
  }
}
