{
  "description": "Theorem Context lifecycle hooks for Codex. Out-of-band orchestration before each model turn; context/frontier capture around tool use; run finalization at session end.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/hook-doctor.sh\" SessionStart",
            "timeout": 5,
            "statusMessage": "Recording hook receipt"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/begin-run.sh\"",
            "timeout": 15,
            "statusMessage": "Starting theorem harness run"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/sessionstart-codebase.sh\"",
            "timeout": 10,
            "statusMessage": "Loading codebase context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/inject-harness-directives.sh\"",
            "timeout": 5,
            "statusMessage": "Injecting harness directives"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/sessionstart-writing-engineering.sh\"",
            "timeout": 5,
            "statusMessage": "Arming writing engineering mode"
          },
          {
            "type": "command",
            "command": "/bin/bash -lc 'command -v node >/dev/null 2>&1 && node \"${PLUGIN_ROOT}/scripts/ponytail-activate.js\" || exit 0'",
            "timeout": 5,
            "statusMessage": "Loading ponytail mode"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/hook-doctor.sh\" UserPromptSubmit",
            "timeout": 5,
            "statusMessage": "Recording hook receipt"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/prepare-context.sh\"",
            "timeout": 30,
            "statusMessage": "Preparing theorem context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/code-neighborhood.sh\"",
            "timeout": 30,
            "statusMessage": "Composing code neighborhood"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/inject-harness-directives.sh\"",
            "timeout": 5,
            "statusMessage": "Injecting harness directives"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/checklist-contract.sh\"",
            "timeout": 10,
            "statusMessage": "Emitting harness checklist"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/subagent-suggest.sh\"",
            "timeout": 10,
            "statusMessage": "Suggesting subagents"
          },
          {
            "type": "command",
            "command": "/bin/bash -lc 'command -v node >/dev/null 2>&1 && node \"${PLUGIN_ROOT}/scripts/ponytail-mode-tracker.js\" || exit 0'",
            "timeout": 5,
            "statusMessage": "Tracking ponytail mode"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_theorems[-_]harness_.*|mcp__theorems[-_]harness(__|[._]).*|mcp__codex_apps__theorems[-_]harness(__|[._]).*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/auto-approve-harness.sh\"",
            "timeout": 5,
            "statusMessage": "Authorizing harness tool"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/hook-doctor.sh\" PostToolUse",
            "timeout": 5,
            "statusMessage": "Recording hook receipt"
          }
        ]
      },
      {
        "matcher": "Bash|exec_command|functions.exec_command|apply_patch|functions.apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/record-action.sh\"",
            "timeout": 10,
            "statusMessage": "Recording theorem action"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/posttool-context.sh\"",
            "timeout": 10,
            "statusMessage": "Recording post-tool context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/posttool-event.sh\"",
            "timeout": 10,
            "statusMessage": "Recording coordination event"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/delta-queue.sh\"",
            "timeout": 5,
            "statusMessage": "Queueing code-delta paths"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/hook-doctor.sh\" Stop",
            "timeout": 5,
            "statusMessage": "Recording hook receipt"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/checklist-gate.sh\"",
            "timeout": 10,
            "statusMessage": "Checking harness checklist"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/repo-hygiene-receipt.sh\"",
            "timeout": 25,
            "statusMessage": "Reviewing repository hygiene"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/review-checks.sh\"",
            "timeout": 60,
            "statusMessage": "Running changed-language review checks"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/stop-style-receipt.sh\"",
            "timeout": 10,
            "statusMessage": "Recording writing style receipt"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/stop-design-receipt.sh\"",
            "timeout": 15,
            "statusMessage": "Recording design engineering receipt"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/sessionend-context.sh\"",
            "timeout": 10,
            "statusMessage": "Flushing session-end context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/finalize-run.sh\"",
            "timeout": 30,
            "statusMessage": "Finalizing theorem run"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/code-use-receipt.sh\"",
            "timeout": 15,
            "statusMessage": "Recording code-use receipts"
          }
        ]
      }
    ]
  }
}
