{
  "description": "Theorem Context lifecycle hooks for Codex. Out-of-band orchestration before each model turn; context/frontier capture around tool use; run finalization at session end.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/begin-run.sh\"",
            "timeout": 15,
            "statusMessage": "Starting theorem harness run"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/sessionstart-codebase.sh\"",
            "timeout": 10,
            "statusMessage": "Loading codebase context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/inject-harness-directives.sh\"",
            "timeout": 5,
            "statusMessage": "Injecting harness directives"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/prepare-context.sh\"",
            "timeout": 30,
            "statusMessage": "Preparing theorem context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/inject-harness-directives.sh\"",
            "timeout": 5,
            "statusMessage": "Injecting harness directives"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/checklist-contract.sh\"",
            "timeout": 10,
            "statusMessage": "Emitting harness checklist"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/subagent-suggest.sh\"",
            "timeout": 10,
            "statusMessage": "Suggesting subagents"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/posttool-blocker-scan.sh\"",
            "timeout": 5,
            "statusMessage": "Scanning for deferral signals"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_theorems-harness_.*|mcp__theorems-harness__.*|mcp__rustyred-thg__.*",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/auto-approve-harness.sh\"",
            "timeout": 5,
            "statusMessage": "Authorizing harness tool"
          }
        ]
      },
      {
        "matcher": "Bash|exec_command|functions.exec_command|apply_patch|functions.apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/enforce-action-rail.sh\"",
            "timeout": 5,
            "statusMessage": "Checking theorem action rail"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/pretool-context.sh\"",
            "timeout": 10,
            "statusMessage": "Loading pre-tool context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|exec_command|functions.exec_command|apply_patch|functions.apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/record-action.sh\"",
            "timeout": 10,
            "statusMessage": "Recording theorem action"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/posttool-context.sh\"",
            "timeout": 10,
            "statusMessage": "Recording post-tool context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/posttool-event.sh\"",
            "timeout": 10,
            "statusMessage": "Recording coordination event"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/checklist-gate.sh\"",
            "timeout": 10,
            "statusMessage": "Checking harness checklist"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/sessionend-context.sh\"",
            "timeout": 10,
            "statusMessage": "Flushing session-end context"
          },
          {
            "type": "command",
            "command": "/bin/bash \"${PLUGIN_ROOT}/scripts/finalize-run.sh\"",
            "timeout": 30,
            "statusMessage": "Finalizing theorem run"
          }
        ]
      }
    ]
  }
}
