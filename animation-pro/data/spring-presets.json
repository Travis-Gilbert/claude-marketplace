{
  "presets": {
    "snappy": {
      "description": "Fast, no bounce. Buttons, dropdowns, menus.",
      "motion": { "stiffness": 400, "damping": 30 },
      "react-spring": { "tension": 400, "friction": 30 }
    },
    "natural": {
      "description": "Medium, slight settle. Panels, drawers, cards.",
      "motion": { "stiffness": 300, "damping": 25 },
      "react-spring": { "tension": 300, "friction": 25 }
    },
    "gentle": {
      "description": "Slow, smooth. Content reveals, page transitions.",
      "motion": { "stiffness": 200, "damping": 20 },
      "react-spring": { "tension": 200, "friction": 20 }
    },
    "bouncy": {
      "description": "Playful overshoot. Game elements, playful UI.",
      "motion": { "stiffness": 500, "damping": 15 },
      "react-spring": { "tension": 500, "friction": 15 }
    },
    "critical": {
      "description": "No overshoot. Destructive confirmations, modals.",
      "motion": { "stiffness": 400, "damping": 40 },
      "react-spring": { "tension": 400, "friction": 40 }
    },
    "heavy": {
      "description": "Weighty, deliberate. Large panels, full-screen overlays.",
      "motion": { "stiffness": 150, "damping": 25, "mass": 1.5 },
      "react-spring": { "tension": 150, "friction": 25, "mass": 1.5 }
    }
  }
}
